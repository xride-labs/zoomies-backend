# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
MOBILE_APP_URL="exp://localhost:8081"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-32-char-random-secret"
BETTER_AUTH_BASE_URL="http://localhost:5000"
AUTH_URL="http://localhost:5000"
# Root domain for cross-subdomain cookie sharing (e.g. .yourdomain.com). Leave empty in dev.
BETTER_AUTH_COOKIE_DOMAIN=".yourdomain.com"

# ─── Database ─────────────────────────────────────────────────────────────────
# Local: postgresql://USER:PASSWORD@localhost:5432/zoomies_dev
# Neon:  postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://admin:admin123@localhost:5432/zoomies_dev"
MONGODB_URI="mongodb://admin:admin123@localhost:27017/zoomies?authSource=admin"

# ─── OAuth ────────────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get credentials at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Cloudflare R2 (Fallback Storage) ─────────────────────────────────────────
# Only used when Cloudinary hits its storage/plan limit.
# Setup: dash.cloudflare.com → R2 → Create bucket → Enable public access → Create API token
# Account ID is shown in the right sidebar on any Cloudflare dashboard page.
R2_ACCOUNT_ID="your-32-char-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="zoomies-media"
# R2.dev subdomain (enable in bucket settings) or your custom CDN domain
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev"

# ─── Payments (Dodo) ──────────────────────────────────────────────────────────
# Get keys at: https://dashboard.dodopayments.com → Settings → API Keys
# Use test_mode for dev, live_mode for production
DODO_PAYMENTS_API_KEY="dp_test_your-api-key"
DODO_PAYMENTS_ENVIRONMENT="test_mode"
DODO_PAYMENTS_BASE_URL="https://test.dodopayments.com"
DODO_PAYMENTS_WEBHOOK_KEY="whsec_your-webhook-secret"
DODO_PRO_MONTHLY_PRODUCT_ID="pdt_your-monthly-product-id"
DODO_PRO_ANNUAL_PRODUCT_ID="pdt_your-annual-product-id"
DODO_PAYMENTS_RETURN_URL="zoomies://payments/callback"
DODO_PAYMENTS_CANCEL_URL="zoomies://payments/callback?status=cancelled"

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
# Get API key at: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY="your-brevo-api-key"
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="Zoomies"
BREVO_REPLY_TO="support@yourdomain.com"

# ─── Expo ─────────────────────────────────────────────────────────────────────
# Generate at: https://expo.dev/accounts/[username]/settings/access-tokens
EXPO_ACCESS_TOKEN="your-expo-access-token"

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Any strong random string — used as Bearer token for the /api/admin/metrics endpoint
METRICS_BEARER_TOKEN="replace-with-strong-random-string"

# ─── Sentry (Backend) ─────────────────────────────────────────────────────────
SENTRY_DSN=""
# Optional overrides
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# ─── Background Jobs ──────────────────────────────────────────────────────────
RIDE_RETENTION_DAYS=30

# ─── Keep-Alive Ping ──────────────────────────────────────────────────────────
SELF_PING_ENABLED=true
SELF_PING_PRODUCTION_ONLY=true
SELF_PING_INTERVAL_MINUTES=10
# SELF_PING_URL="https://your-service.onrender.com/health"
# RENDER_EXTERNAL_URL="https://your-service.onrender.com"

# ─── Optional: Twilio SMS ─────────────────────────────────────────────────────
# If unset, SMS OTP is disabled. Get credentials at: https://console.twilio.com
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# TWILIO_PHONE_NUMBER="+1234567890"

# ─── Optional: Redis (Socket.io adapter) ──────────────────────────────────────
# Required only if running multiple backend instances behind a load balancer
# REDIS_URL="redis://localhost:6379"
