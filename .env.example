# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL Database URL
# Local format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://admin:admin123@localhost:5432/zoomies_dev"

# MongoDB Connection String
MONGODB_URI="mongodb://admin:admin123@localhost:27017/"

# ===========================================
# Better Auth Configuration
# ===========================================

# REQUIRED: Generate a strong random secret for production
BETTER_AUTH_SECRET="replace-me-with-a-strong-secret"

# Backend public base URL used by Better Auth callbacks
BETTER_AUTH_BASE_URL="http://localhost:5000"

# Optional fallback (used when BETTER_AUTH_BASE_URL is unset)
AUTH_URL="http://localhost:5000"

# Force email verification for email/password sign-ins (true/false)
# Defaults to true in production automatically.
AUTH_REQUIRE_EMAIL_VERIFICATION="false"

# ===========================================
# OAuth Providers
# ===========================================

AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ===========================================
# Twilio SMS Configuration (Optional)
# ===========================================

# If these are not set, SMS OTP is disabled.
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# TWILIO_PHONE_NUMBER="+1234567890"

# ===========================================
# Server Configuration
# ===========================================

PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
MOBILE_APP_URL="exp://localhost:8081"
# Optional: comma-separated origins to trust for both Better Auth and CORS
# Example: "http://localhost:3001,https://preview.zoomies.example"
ADDITIONAL_TRUSTED_ORIGINS=""

# ===========================================
# Monitoring Configuration
# ===========================================

METRICS_BEARER_TOKEN="change-me"

# ===========================================
# Optional: Email Configuration (Brevo)
# ===========================================

# BREVO_API_KEY="your-brevo-api-key"
# BREVO_SENDER_EMAIL="noreply@yourdomain.com"
# BREVO_SENDER_NAME="Zoomies"
# BREVO_REPLY_TO="support@yourdomain.com"

# ===========================================
# Dodo Payments Configuration
# ===========================================

# Required to create checkout sessions and customer portal links.
# Use test_mode during development and live_mode in production.
# DODO_PAYMENTS_API_KEY="dp_test_xxxxxxxxx"
# DODO_PAYMENTS_ENVIRONMENT="test_mode"
# DODO_PAYMENTS_BASE_URL="https://test.dodopayments.com"
# DODO_PAYMENTS_WEBHOOK_KEY="whsec_xxxxxxxxx"

# Product IDs from your Dodo dashboard for Zoomies Pro.
# DODO_PRO_MONTHLY_PRODUCT_ID="pdt_xxxxxxxxx"
# DODO_PRO_ANNUAL_PRODUCT_ID="pdt_xxxxxxxxx"

# Mobile deep link return/cancel URLs. The app scheme is zoomies:// by default.
# DODO_PAYMENTS_RETURN_URL="zoomies://payments/callback"
# DODO_PAYMENTS_CANCEL_URL="zoomies://payments/callback?status=cancelled"

# ===========================================
# Cloudinary Configuration (for media uploads)
# ===========================================

CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ===========================================
# Optional: Socket.io Redis Adapter
# ===========================================

# REDIS_URL="redis://localhost:6379"

# ===========================================
# Background Jobs Configuration
# ===========================================

RIDE_RETENTION_DAYS=30

# ===========================================
# Keep-Alive Self Ping (Render/Free Tier)
# ===========================================

SELF_PING_ENABLED=true
SELF_PING_PRODUCTION_ONLY=true
SELF_PING_INTERVAL_MINUTES=10

# Optional explicit URL to ping (recommended in production)
# SELF_PING_URL="https://your-service.onrender.com/health"

# Optional fallback base URL (if SELF_PING_URL is unset)
# RENDER_EXTERNAL_URL="https://your-service.onrender.com"

