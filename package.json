{
  "name": "zoomies-backend",
  "version": "1.0.0",
  "description": "Zoomies Backend API with Express, Prisma, and Better Auth",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "bun run prisma:generate && tsc",
    "start": "bun run node dist/src/server.js",
    "start:with-db": "bun run prisma:deploy && bun run db:seed:prod && bun run start",
    "deploy:render": "bun run prisma:deploy && bun run db:seed:prod",
    "build:render": "bun run build",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:deploy": "bunx prisma migrate deploy",
    "prisma:studio": "bunx prisma studio",
    "prisma:reset": "bunx prisma migrate reset --force",
    "prisma:status": "bunx prisma migrate status",
    "prisma:validate": "bunx prisma validate",
    "prisma:format": "bunx prisma format",
    "db:push": "bunx prisma db push",
    "db:pull": "bunx prisma db pull",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "NODE_ENV=production node dist/prisma/seed.js",
    "postinstall": "bun run prisma:generate",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "bun run test:routes",
    "test:all": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles",
    "test:routes": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles src/routes",
    "test:smoke": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles src/http.contract.test.ts",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage"
  },
  "keywords": [
    "express",
    "typescript",
    "prisma",
    "better-auth"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.4.18",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^8.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "standardwebhooks": "^1.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2"
  }
}
