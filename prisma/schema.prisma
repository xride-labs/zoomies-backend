// ─── Phase 9: Brand Products (first-party catalog, separate from P2P marketplace)

enum BrandProductCategory {
  MOTORCYCLE
  GEAR
  HELMET
  JACKET
  GLOVES
  BOOTS
  PANTS
  PARTS
  ACCESSORIES
  ELECTRONICS
  TOOLS
  LUBRICANTS
  TYRES
  LIGHTING
  APPAREL
  MEMORABILIA
  OTHER
}

enum ProductAvailability {
  IN_STOCK
  OUT_OF_STOCK
  PRE_ORDER
  DISCONTINUED
}

model BrandProduct {
  id           String               @id @default(cuid())
  businessId   String               @map("business_id")
  title        String
  description  String?              @db.Text
  sku          String?
  category     BrandProductCategory @default(OTHER)
  price        Float?
  currency     String               @default("INR")
  images       String[]
  availability ProductAvailability  @default(IN_STOCK)
  tags         String[]             @default([])
  specs        Json?
  isActive     Boolean              @default(true) @map("is_active")
  isFeatured   Boolean              @default(false) @map("is_featured")

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([businessId, isActive], map: "brand_product_business_idx")
  @@map("brand_products")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS - Track notifications sent to users
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationType {
  // Ride
  RIDE_INVITE // Invited to a ride
  RIDE_JOINED // Someone joined your ride
  RIDE_COMPLETED // Ride completed reminder
  RIDE_REMINDER // 30-min reminder before a scheduled ride
  RIDE_STARTED // Creator started the ride — notify participants
  RIDE_CANCELLED // Creator cancelled the ride — notify participants
  RIDE_REQUEST // Someone requested to join your ride
  // Club
  CLUB_INVITE // Invited to a club
  CLUB_REQUEST // New club join request
  // Marketplace
  LISTING_OFFER // Received an offer on your listing
  LISTING_INTERESTED // Someone marked interest in your listing
  LISTING_SOLD // Your listing was marked as sold
  // Social
  MESSAGE // New chat message
  FOLLOW // New follower
  COMMENT // Comment on your post
  LIKE // Like on your post
  FRIEND_REQUEST // Friend request received
  FRIEND_ACCEPTED // Your friend request was accepted
  // Events
  EVENT_INVITE // Invited to a club event
  EVENT_REMINDER // 1-hour reminder before an event
  // Safety
  SOS_ALERT // Emergency triggered in a live ride you're part of
  // Gamification
  BADGE_EARNED // You earned a new badge
  // Business / admin
  BUSINESS_APPROVED // Your brand/business profile was approved
  BUSINESS_REJECTED // Your brand/business profile was rejected
  SYSTEM_ALERT // Platform-wide message from admin
}

model Notification {
  id      String           @id @default(cuid())
  userId  String           @map("user_id")
  type    NotificationType
  title   String
  message String?

  // Link to the related entity
  relatedType String? @map("related_type") // "ride", "club", "listing", "user", "post", etc
  relatedId   String? @map("related_id")

  // Delivery tracking
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  // Delivery channels
  sentViaEmail Boolean @default(false) @map("sent_via_email")
  sentViaPush  Boolean @default(false) @map("sent_via_push")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Composite indexes replace the three single-column ones:
  // • (userId, isRead, createdAt DESC) → covers unread-count + unread-feed queries
  // • (userId, createdAt DESC)         → covers all-notifications-feed query
  // The old idx_notification_read (boolean) had near-zero selectivity and
  // idx_notification_created alone never matched a useful WHERE clause.
  @@index([userId, isRead, createdAt(sort: Desc)], map: "idx_notification_user_unread")
  @@index([userId, createdAt(sort: Desc)], map: "idx_notification_user_feed")
  @@map("notifications")
}

// Global & Club Events
enum EventStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  location    String?
  latitude    Float?
  longitude   Float?
  scheduledAt DateTime    @map("scheduled_at")
  endedAt     DateTime?   @map("ended_at")
  status      EventStatus @default(PLANNED)

  // Featured / Promotion
  isFeatured  Boolean @default(false) @map("is_featured")
  bannerImage String? @map("banner_image")
  ticketUrl   String? @map("ticket_url")

  // Ownership
  creatorId String  @map("creator_id")
  clubId    String? @map("club_id")
  creator   User    @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  club      Club?   @relation("ClubEvents", fields: [clubId], references: [id], onDelete: Cascade)

  // Attendees
  participants EventParticipant[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([latitude, longitude], map: "events_geo_idx")
  @@index([status, scheduledAt], map: "events_status_scheduled_idx")
  @@map("events")
}

model EventParticipant {
  id      String                @id @default(cuid())
  eventId String                @map("event_id")
  userId  String                @map("user_id")
  status  RideParticipantStatus @default(REQUESTED) // Reusing RideParticipantStatus (ACCEPTED, CANCELLED, etc)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation("EventParticipations", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([eventId, userId])
  @@map("event_participants")
}
