// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Better Auth required models
model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id") // Provider's account ID or equal to userId for credentials
  providerId            String    @map("provider_id") // e.g., "credential", "google", "phone"
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token") @db.Text
  password              String? // For credential accounts
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique // Session token
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  name          String?
  email         String?   @unique
  dob           DateTime? // Date of birth
  bloodType     String?   @map("blood_type") // e.g., "O+", "A-", "B+", "AB-"
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String? // OAuth profile image (Better Auth default field)
  avatar        String? // App profile picture URL (legacy/custom field)
  coverImage    String?   @map("cover_image") // Cover/banner image URL
  phone         String?   @unique // For mobile OTP
  phoneVerified Boolean   @default(false) @map("phone_verified")

  // Profile fields
  bio                 String?
  location            String?
  interests           String[] @default([]) // List of user interests (e.g. touring, sports)
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")

  // Experience system
  xpPoints        Int?   @default(0) @map("xp_points") // Total experience points
  level           Int    @default(1) // Current level (1-100)
  levelTitle      String @default("Beginner") @map("level_title") // e.g., "Road Warrior", "Highway Legend"
  reputationScore Float? @default(0) @map("reputation_score") // 0.0 to 5.0
  activityLevel   String @default("Casual") @map("activity_level") // e.g., "Casual", "Regular", "Enthusiast", "Pro"

  // Safety fields
  helmetVerified  Boolean   @default(false) @map("helmet_verified")
  lastSafetyCheck DateTime? @map("last_safety_check")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Multi-role support (replaces single role field)
  userRoles UserRoleAssignment[]

  // Subscription & Billing
  subscriptionTier String? @default("FREE") @map("subscription_tier") // Derived snapshot for fast gating

  // Relations
  accounts            Account[]
  sessions            Session[]
  createdRides        Ride[]               @relation("RideCreator")
  rideParticipations  RideParticipant[]
  createdEvents       Event[]              @relation("EventCreator")
  eventParticipations EventParticipant[]   @relation("EventParticipations")
  createdClubs        Club[]               @relation("ClubOwner")
  clubMemberships     ClubMember[]
  clubJoinRequests    ClubJoinRequest[]
  marketplaceListings MarketplaceListing[] @relation("SellerListings")
  chatMessages        ChatMessage[]
  posts               Post[]
  likes               Like[]
  comments            Comment[]
  followers           Follow[]             @relation("Following")
  following           Follow[]             @relation("Followers")
  receivedReviews     Review[]             @relation("ReviewReceiver")
  reportsFiled        Report[]             @relation("ReportReporter")

  // New relations for comprehensive profile
  bikes                   Bike[]
  badges                  UserBadge[]
  emergencyContacts       EmergencyContact[]
  preferences             UserPreferences?
  rideStats               UserRideStats?
  friendsInitiated        Friendship[]             @relation("FriendInitiator")
  friendsReceived         Friendship[]             @relation("FriendReceiver")
  friendGroupsOwned       FriendGroup[]            @relation("FriendGroupOwner")
  friendGroupMemberships  FriendGroupMember[]
  friendGroupJoinRequests FriendGroupJoinRequest[]
  liveLocation            UserLiveLocation?

  // Ride rating relations
  rideRatingsGiven    RideRating[] @relation("RideRatingGiver")
  rideRatingsReceived RideRating[] @relation("RideRatingReceiver")

  // Ride lifecycle (breaks/detours) relations
  rideBreaks  RideBreak[]
  rideDetours RideDetour[]

  // Marketplace relations
  listingOffersMade ListingOffer[]    @relation("ListingOffersBuyer")
  listingInterests  ListingInterest[] @relation("ListingInterests")

  // Notification relations
  notifications        Notification[]
  deviceTokens         DeviceToken[]
  billingSubscriptions BillingSubscription[]

  // Phase 6: business profiles owned by this user (brand owners, sellers,
  // service stores, mechanics, etc.). One user can own multiple businesses.
  businessProfiles BusinessProfile[]

  // Phase 8: brand team membership + inquiries
  brandMemberships  BrandMember[]     @relation("BrandMemberships")
  brandInvitesSent  BrandMember[]     @relation("BrandInviter")
  businessInquiries BusinessInquiry[] @relation("InquiriesMade")

  @@map("users")
}

/**
 * Push-notification device registration. Stores ExpoPushTokens (which the
 * Expo push service translates to FCM/APNs internally) + minimal device
 * metadata so users can revoke a single device without losing all sessions.
 */
model DeviceToken {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  token      String   @unique
  platform   String // "ios" | "android"
  deviceId   String?  @map("device_id")
  appVersion String?  @map("app_version")
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_device_token_user")
  @@index([lastSeenAt], map: "idx_device_token_stale") // used by stale-token cleanup cron
  @@map("device_tokens")
}

model BillingSubscription {
  id                     String    @id @default(cuid())
  userId                 String    @map("user_id")
  provider               String    @default("DODO")
  providerCustomerId     String?   @map("provider_customer_id")
  providerSubscriptionId String    @unique @map("provider_subscription_id")
  tier                   String    @default("PRO")
  plan                   String?
  status                 String
  currentPeriodEnd       DateTime? @map("current_period_end")
  cancelAt               DateTime? @map("cancel_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([providerCustomerId])
  @@map("billing_subscriptions")
}

// Application-specific models for Phase 1 MVP

// User roles for role-based access control
enum UserRole {
  ADMIN // Super admin with full platform access (web + mobile)
  CO_ADMIN // Delegated admin with broad dashboard access
  MODERATOR // Platform moderator - can moderate content, handle reports
  CLUB_OWNER // Club creator/manager (web + mobile)
  CLUB_ADMIN // Club admin/co-admin
  CLUB_MODERATOR // Club moderator
  BRAND_OWNER // Brand/business owner
  BRAND_ADMIN // Brand admin/co-admin
  BRAND_MODERATOR // Brand moderator
  RIDER // Default role for new signups - active motorcycle rider (mobile)
  SELLER // Marketplace seller - assigned when user lists items (web + mobile)
}

// Platform-wide admin settings (single-row, scope = "global")
model AdminSettings {
  id           String @id @default(cuid())
  scope        String @unique @default("global")
  siteName     String @default("Zoomies") @map("site_name")
  siteUrl      String @default("https://zoomies.app") @map("site_url")
  supportEmail String @default("support@zoomies.app") @map("support_email")
  timezone     String @default("America/Phoenix")

  maintenanceMode     Boolean @default(false) @map("maintenance_mode")
  allowRegistration   Boolean @default(true) @map("allow_registration")
  marketplaceEnabled  Boolean @default(true) @map("marketplace_enabled")
  clubCreationEnabled Boolean @default(true) @map("club_creation_enabled")

  requireAdmin2FA       Boolean @default(false) @map("require_admin_2fa")
  sessionTimeoutMinutes Int     @default(30) @map("session_timeout_minutes")
  passwordStrength      String  @default("strong") @map("password_strength")
  loginAttempts         Int     @default(5) @map("login_attempts")

  notifyNewUser          Boolean @default(true) @map("notify_new_user")
  notifyNewReports       Boolean @default(true) @map("notify_new_reports")
  notifyClubVerification Boolean @default(true) @map("notify_club_verification")
  notifySystemAlerts     Boolean @default(true) @map("notify_system_alerts")
  notifyDailySummary     Boolean @default(false) @map("notify_daily_summary")

  smtpHost            String @default("smtp.sendgrid.net") @map("smtp_host")
  smtpPort            Int    @default(587) @map("smtp_port")
  smtpUser            String @default("apikey") @map("smtp_user")
  smtpPass            String @default("") @map("smtp_pass")
  fromEmail           String @default("noreply@zoomies.app") @map("from_email")
  fromName            String @default("Zoomies") @map("from_name")
  welcomeEmailSubject String @default("Welcome to Zoomies!") @map("welcome_email_subject")
  welcomeEmailBody    String @default("Hi {{name}}, Welcome to Zoomies!") @map("welcome_email_body")

  primaryColor    String  @default("#f97316") @map("primary_color")
  darkModeDefault Boolean @default(false) @map("dark_mode_default")
  compactMode     Boolean @default(false) @map("compact_mode")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_settings")
}

// Many-to-many user role assignments (multi-role support)
model UserRoleAssignment {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  role       UserRole
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_role_assignments")
}

// Media model for tracking uploaded files
model Media {
  id           String    @id @default(cuid())
  publicId     String    @unique @map("public_id") // Cloudinary public ID
  url          String
  secureUrl    String    @map("secure_url")
  thumbnailUrl String?   @map("thumbnail_url")
  type         MediaType
  format       String?
  width        Int?
  height       Int?
  bytes        Int?
  duration     Float? // For videos, in seconds
  folder       String // Cloudinary folder

  // Polymorphic associations
  userId    String? @map("user_id")
  clubId    String? @map("club_id")
  rideId    String? @map("ride_id")
  listingId String? @map("listing_id")
  postId    String? @map("post_id")

  // Phase 5 retention. `retentionPolicy` is a free-form tag that maps to a
  // policy in retention.service (e.g. "SHARED_24H", "PROFILE_PERMANENT").
  // `expiresAt` is the resolved deadline; the daily cleanup job deletes any
  // row past it from both Postgres and Cloudinary. Null means keep forever.
  retentionPolicy String?   @map("retention_policy")
  expiresAt       DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([expiresAt], map: "media_expires_at_idx")
  @@map("media")
}

enum MediaType {
  IMAGE
  VIDEO
}

// ─── Phase 6: Business / Brand Portal ────────────────────────────────────────

enum BusinessCategory {
  BRAND // motorcycle brands (Triumph, Royal Enfield, ...)
  GEAR_SELLER // jackets, gloves, riding pants
  HELMET_SELLER
  PARTS_SELLER // spares, accessories
  MARKETPLACE_SELLER // generic seller (new + second-hand)
  CLUB // alias for clubs that want a public business page
  SERVICE_STORE
  MECHANIC
  CONSULTATION
}

enum BusinessVerificationStatus {
  PENDING // draft — owner is still filling in details
  SUBMITTED // sent for admin review
  APPROVED // visible publicly
  REJECTED // admin rejected; verificationNotes explains why
}

/**
 * Business / brand profile. Owners can set up a public storefront for any
 * supported category. Verification is required before the profile shows up
 * in discovery — admins approve via the admin portal.
 */
model BusinessProfile {
  id                  String                     @id @default(cuid())
  ownerId             String                     @map("owner_id")
  categories          BusinessCategory[]
  displayName         String                     @map("display_name")
  // URL-safe slug used in deep links (zoomies://business/<slug>) and the
  // public web mirror. Generated from displayName at create time; uniqueness
  // is enforced so two businesses can't share a slug.
  slug                String                     @unique
  tagline             String?
  description         String?                    @db.Text
  logoUrl             String?                    @map("logo_url")
  bannerUrl           String?                    @map("banner_url")
  // Contact + location. All optional so the wizard can save partial drafts.
  phone               String?
  email               String?
  websiteUrl          String?                    @map("website_url")
  addressLine1        String?                    @map("address_line1")
  addressLine2        String?                    @map("address_line2")
  city                String?
  region              String?
  country             String?
  latitude            Float?
  longitude           Float?
  pricingTier         String?                    @map("pricing_tier") // BASIC | PRO | ENTERPRISE
  // Brand portal subscription — FREE (default) or PRO (paid via Dodo).
  brandTier           String                     @default("FREE") @map("brand_tier")
  brandProExpiresAt   DateTime?                  @map("brand_pro_expires_at")
  onboardingCompleted Boolean                    @default(false) @map("onboarding_completed")
  // Verification state machine. Only APPROVED profiles surface in discovery.
  verification        BusinessVerificationStatus @default(PENDING)
  verificationNotes   String?                    @map("verification_notes") @db.Text
  // Free-form list of uploaded verification docs:
  // [{ type: "GST" | "TRADE_LICENSE" | "ID_PROOF", url, uploadedAt }]
  documents           Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Phase 7 back-relations — campaigns and discounts the business owns.
  campaigns AdCampaign[]
  discounts Discount[]
  // Phase 8: team, services, and inquiries
  members   BrandMember[]
  services  ServiceListing[]
  inquiries BusinessInquiry[]
  // Phase 9: first-party product catalog
  products  BrandProduct[]

  @@index([verification], map: "business_category_status_idx")
  @@index([latitude, longitude], map: "business_geo_idx")
  @@index([ownerId], map: "business_owner_idx")
  @@map("business_profiles")
}

// ─── Phase 8: Brand Teams ────────────────────────────────────────────────────

enum BrandMemberRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

model BrandMember {
  id         String          @id @default(cuid())
  businessId String          @map("business_id")
  userId     String          @map("user_id")
  role       BrandMemberRole @default(MEMBER)
  invitedBy  String?         @map("invited_by")
  joinedAt   DateTime        @default(now()) @map("joined_at")

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User            @relation("BrandMemberships", fields: [userId], references: [id], onDelete: Cascade)
  inviter  User?           @relation("BrandInviter", fields: [invitedBy], references: [id])

  @@unique([businessId, userId])
  @@index([businessId], map: "brand_member_business_idx")
  @@map("brand_members")
}

// ─── Phase 8: Service Listings (garages + mechanics) ────────────────────────

enum ServiceCategory {
  GENERAL_SERVICE
  OIL_CHANGE
  BRAKE_SERVICE
  TYRE_CHANGE
  ELECTRICAL
  SUSPENSION
  ENGINE_WORK
  CUSTOM_MODIFICATION
  INSPECTION
  ROADSIDE_ASSISTANCE
  CONSULTATION
}

model ServiceListing {
  id          String          @id @default(cuid())
  businessId  String          @map("business_id")
  title       String
  description String?         @db.Text
  category    ServiceCategory @default(GENERAL_SERVICE)
  priceRange  String?         @map("price_range")
  duration    String?
  isActive    Boolean         @default(true) @map("is_active")

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([businessId, isActive], map: "service_listing_business_idx")
  @@map("service_listings")
}

// ─── Phase 8: Business Inquiries ─────────────────────────────────────────────

enum InquiryStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model BusinessInquiry {
  id         String        @id @default(cuid())
  businessId String        @map("business_id")
  fromUserId String        @map("from_user_id")
  subject    String
  message    String        @db.Text
  status     InquiryStatus @default(OPEN)

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fromUser User            @relation("InquiriesMade", fields: [fromUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([businessId], map: "inquiry_business_idx")
  @@index([fromUserId], map: "inquiry_user_idx")
  @@map("business_inquiries")
}

// ─── Phase 7: Ads + Discounts ───────────────────────────────────────────────

enum AdPlacementSlot {
  HOME_FEED // top of the home tab
  DISCOVER_TOP // discover tab hero
  MARKETPLACE_INLINE // injected between marketplace listings
  CHAT_LIST_TOP // top of the conversations list
  POST_RIDE_SUMMARY // shown on the summary screen (NOT during the ride)
}

enum AdStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

/**
 * Direct-sold ad campaign owned by a business. Admin moderates state
 * transitions (DRAFT/PENDING → ACTIVE/REJECTED). Free-tier users see
 * approved campaigns in the slots they target; Pro users see none.
 * Ad serving in this app is *intentionally simple*: pick the next ACTIVE
 * campaign that targets the requested slot and is within its run window.
 * No bidding, no exchange — Phase 7 is a managed-list system.
 */
model AdCampaign {
  id         String          @id @default(cuid())
  businessId String          @map("business_id")
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title    String
  ctaLabel String  @map("cta_label")
  ctaUrl   String? @map("cta_url")
  // App-internal deep link (e.g. "business/<id>"). When present, taps route
  // in-app instead of opening the external URL.
  deepLink String? @map("deep_link")
  imageUrl String  @map("image_url")
  videoUrl String? @map("video_url")

  startsAt        DateTime          @map("starts_at")
  endsAt          DateTime          @map("ends_at")
  budgetPaise     Int               @default(0) @map("budget_paise")
  status          AdStatus          @default(DRAFT)
  slots           AdPlacementSlot[]
  // Coarse targeting tags — ride styles, regions, anything that helps the
  // backend pick a relevant campaign for the requesting user. Free-form
  // strings; meaning is decided by the targeting service.
  targetTags      String[]          @map("target_tags")
  impressionCap   Int?              @map("impression_cap")
  impressionCount Int               @default(0) @map("impression_count")
  clickCount      Int               @default(0) @map("click_count")
  reviewNotes     String?           @map("review_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, startsAt, endsAt], map: "ad_campaign_status_window_idx")
  @@index([businessId], map: "ad_campaign_owner_idx")
  @@map("ad_campaigns")
}

/**
 * Promotional discount or offer attached to a business. Surfaced via the
 * /discounts feed and on the business's public page.
 */
model Discount {
  id         String          @id @default(cuid())
  businessId String          @map("business_id")
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  code           String?  @unique
  title          String
  description    String?  @db.Text
  imageUrl       String?  @map("image_url")
  percentOff     Int?     @map("percent_off")
  amountOffPaise Int?     @map("amount_off_paise")
  validFrom      DateTime @map("valid_from")
  validUntil     DateTime @map("valid_until")
  // Free-form list of category/product IDs the discount applies to.
  appliesTo      Json?    @map("applies_to")
  isFeatured     Boolean  @default(false) @map("is_featured")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([validFrom, validUntil], map: "discount_window_idx")
  @@index([businessId], map: "discount_owner_idx")
  @@map("discounts")
}

enum RideStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum RideBreakType {
  REST
  FUEL
  FOOD
  PHOTO
  REPAIR
  EMERGENCY
  OTHER
}

enum ClubMemberRole {
  MEMBER // Regular club member
  OFFICER // Club officer/moderator
  ADMIN // Club admin
  FOUNDER // Club founder
}

// Moderation state of a club member. ACTIVE is the normal state; the others
// are driven by the *Until timestamps on ClubMember and re-derived lazily
// (a SUSPENDED member whose suspendedUntil has passed is treated as ACTIVE).
enum ClubMemberStatus {
  ACTIVE
  MUTED // can read but not post in any club group
  SUSPENDED // temporarily removed from posting + group activity
  BANNED // removed from the club; cannot rejoin until bannedUntil
}

// Audit log of every moderation action a club admin takes. Append-only;
// the live state lives on ClubMember for fast checks, this is the history.
enum ClubModerationActionType {
  PROMOTE // role change up (e.g. MEMBER -> ADMIN)
  DEMOTE // role change down
  MUTE
  UNMUTE
  SUSPEND
  UNSUSPEND
  BAN
  UNBAN
  KICK // removed from club (not banned)
}

enum RideParticipantStatus {
  REQUESTED
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
}

model Ride {
  id                  String     @id @default(cuid())
  title               String
  description         String?
  startLocation       String     @map("start_location")
  endLocation         String?    @map("end_location")
  experienceLevel     String?    @map("experience_level") // e.g., Beginner, Intermediate, Expert
  xpRequired          Int?       @map("xp_required")
  pace                String? // e.g., Leisurely, Moderate, Fast
  distance            Float?
  duration            Int? // in minutes
  scheduledAt         DateTime?  @map("scheduled_at")
  endedAt             DateTime?  @map("ended_at") // When ride actually ended
  status              RideStatus @default(PLANNED)
  // Set by the 5-minute reminder cron once the 30-min-before push has fired.
  // Acts as a dedupe flag so the cron's overlapping windows don't notify
  // the same ride twice.
  startReminderSentAt DateTime?  @map("start_reminder_sent_at")

  // Geo coordinates for location-based discovery (mirrors startLat/startLng on write).
  latitude  Float? @map("latitude")
  longitude Float? @map("longitude")

  // Start + end coords for route rendering in the mobile MapPreview.
  startLat Float? @map("start_lat")
  startLng Float? @map("start_lng")
  endLat   Float? @map("end_lat")
  endLng   Float? @map("end_lng")

  // Lifecycle management
  keepPermanently Boolean @default(false) @map("keep_permanently") // Prevent auto-deletion
  isFeatured      Boolean @default(false) @map("is_featured")

  // Route data (for GPS tracking)
  routeData String?  @map("route_data") // JSON string of waypoints
  waypoints Json?    @map("waypoints") // Planned stops: [{latitude, longitude, name?, address?}]
  images    String[] // Array of image URLs

  // Chat fields
  chatGroupId String? @map("chat_group_id")
  chatLocked  Boolean @default(false) @map("chat_locked")

  // Creator relation
  creatorId String @map("creator_id")
  creator   User   @relation("RideCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  // Club relation (optional - for club-organized rides)
  clubId String? @map("club_id")

  // Friend group relation (optional - for group-organized rides)
  friendGroupId String?      @map("friend_group_id")
  friendGroup   FriendGroup? @relation("FriendGroupRides", fields: [friendGroupId], references: [id], onDelete: SetNull)

  // Participants relation
  participants RideParticipant[]

  // Ratings (post-ride ratings of participants)
  ratings RideRating[] @relation("RideRatings")

  // Tracking data (populated during/after live ride)
  trackingData RideTrackingData?

  // Lifecycle: breaks taken + detours added during the ride
  breaks  RideBreak[]
  detours RideDetour[]

  // Pause/resume tracking — set when an active ride is paused, cleared on resume.
  pausedAt DateTime? @map("paused_at")

  // Effective ride metrics — computed once at end-of-ride from
  // actualStartTime/actualEndTime minus break and detour overhead. The
  // top-level `duration` field stays the planned duration in minutes; these
  // fields are the source of truth for the post-ride summary.
  effectiveDurationSec Int?    @map("effective_duration_sec")
  effectiveDistanceKm  Float?  @map("effective_distance_km")
  endedReason          String? @map("ended_reason") // USER_ENDED | TIMEOUT | EMERGENCY

  // Denormalized summary for fast share-card render and historical browsing.
  summary RideSummary?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Indexes for geo-queries and feed performance
  @@index([latitude, longitude], map: "rides_geo_idx")
  @@index([status, scheduledAt], map: "rides_status_scheduled_idx")
  @@index([createdAt], map: "rides_created_idx")
  @@map("rides")
}

// Post-ride summary — denormalized snapshot of computed stats. Generated
// atomically when the ride ends and never recomputed (so badges/score don't
// shift if scoring rules change later).
model RideSummary {
  id     String @id @default(cuid())
  rideId String @unique @map("ride_id")
  ride   Ride   @relation(fields: [rideId], references: [id], onDelete: Cascade)

  totalDistanceKm  Float @default(0) @map("total_distance_km")
  totalDurationSec Int   @default(0) @map("total_duration_sec") // wall-clock from start to end
  movingTimeSec    Int   @default(0) @map("moving_time_sec") // duration minus breaks
  idleTimeSec      Int   @default(0) @map("idle_time_sec") // sum of break durations
  avgSpeedKmh      Float @default(0) @map("avg_speed_kmh")
  maxSpeedKmh      Float @default(0) @map("max_speed_kmh")
  elevationGainM   Float @default(0) @map("elevation_gain_m")
  breakCount       Int   @default(0) @map("break_count")
  detourCount      Int   @default(0) @map("detour_count")

  score            Int      @default(0) // 0..100
  highlights       Json? // ["First 100km ride", "New top speed"]
  badges           String[] // badge slugs awarded for this ride
  routeSnapshotUrl String?  @map("route_snapshot_url") // optional Cloudinary preview

  generatedAt DateTime @default(now()) @map("generated_at")

  @@map("ride_summaries")
}

// Ride tracking data — populated during and after live rides
model RideTrackingData {
  id               String    @id @default(cuid())
  rideId           String    @unique @map("ride_id")
  actualStartTime  DateTime? @map("actual_start_time")
  actualEndTime    DateTime? @map("actual_end_time")
  totalDurationMin Int?      @map("total_duration_min") // excluding breaks
  totalDistanceKm  Float?    @map("total_distance_km")
  maxSpeedKmh      Float?    @map("max_speed_kmh")
  avgSpeedKmh      Float?    @map("avg_speed_kmh")
  elevationGainM   Float?    @map("elevation_gain_m")
  breakCount       Int       @default(0) @map("break_count")
  totalBreakMin    Int       @default(0) @map("total_break_min")
  routeGeoJson     String?   @map("route_geojson") @db.Text // recorded path as GeoJSON
  waypoints        Json? // detours/waypoints added during ride
  weatherNotes     String?   @map("weather_notes")
  riderNotes       String?   @map("rider_notes") @db.Text
  conditions       String? // road conditions (e.g., wet, gravel, clear)

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ride_tracking_data")
}

// Individual break taken during a ride. The Ride model also keeps an
// aggregate (breakCount/totalBreakMin on RideTrackingData) for fast reads,
// but each row here is the source of truth for the post-ride summary.
model RideBreak {
  id          String        @id @default(cuid())
  rideId      String        @map("ride_id")
  ride        Ride          @relation(fields: [rideId], references: [id], onDelete: Cascade)
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        RideBreakType @default(REST)
  startedAt   DateTime      @default(now()) @map("started_at")
  endedAt     DateTime?     @map("ended_at")
  durationSec Int?          @map("duration_sec")
  latitude    Float?
  longitude   Float?
  notes       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([rideId, startedAt], map: "ride_breaks_ride_idx")
  @@index([userId], map: "ride_breaks_user_idx")
  @@map("ride_breaks")
}

// Detour proposed/recorded during a ride. Lives separately from the planned
// route so we can show a "ride deviated here" pin in the post-ride summary.
model RideDetour {
  id               String   @id @default(cuid())
  rideId           String   @map("ride_id")
  ride             Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label            String?
  latitude         Float
  longitude        Float
  distanceAddedKm  Float?   @map("distance_added_km")
  durationAddedMin Int?     @map("duration_added_min")
  addedAt          DateTime @default(now()) @map("added_at")

  @@index([rideId, addedAt], map: "ride_detours_ride_idx")
  @@map("ride_detours")
}

model Club {
  id              String    @id @default(cuid())
  name            String
  description     String?
  location        String?
  establishedAt   DateTime? @map("established_at")
  verified        Boolean   @default(false)
  image           String?
  coverImage      String?   @map("cover_image")
  clubType        String?   @map("club_type") // e.g., Riding Club, Social Club
  isPublic        Boolean   @default(true) @map("is_public")
  requiresLicense Boolean   @default(false) @map("requires_license")
  memberCount     Int       @default(0) @map("member_count")
  trophies        String[] // Array of trophy names or IDs
  trophyCount     Int       @default(0) @map("trophy_count")
  gallery         String[] // Array of image URLs
  reputation      Float? // Average rating of the club
  isFeatured      Boolean   @default(false) @map("is_featured")

  // Geo coordinates for location-based discovery
  latitude  Float? @map("latitude")
  longitude Float? @map("longitude")

  ownerId String @map("owner_id")
  owner   User   @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Members relation
  members           ClubMember[]
  joinRequests      ClubJoinRequest[]
  groups            FriendGroup[]
  moderationActions ClubModerationAction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  events    Event[]  @relation("ClubEvents")

  // Indexes for geo-queries and feed performance
  @@index([latitude, longitude], map: "clubs_geo_idx")
  @@index([memberCount], map: "clubs_member_count_idx")
  @@index([createdAt], map: "clubs_created_idx")
  @@map("clubs")
}

enum ListingStatus {
  ACTIVE
  SOLD
  INACTIVE
}

model MarketplaceListing {
  id             String        @id @default(cuid())
  title          String
  description    String?
  price          Float
  currency       String        @default("INR")
  images         String[] // Array of image URLs
  videos         String[]      @default([]) // Array of video URLs
  category       String? // e.g., Motorcycle, Gear, Accessories
  subcategory    String? // e.g., Helmet, Jacket
  specifications String? // e.g., JSON string of specifications
  condition      String?
  locationLabel  String?       @map("location_label") // Human-friendly location text
  allowBids      Boolean       @default(true) @map("allow_bids")
  status         ListingStatus @default(ACTIVE)

  // Pro-only featured flag — boosted listings sort first in /marketplace.
  // featuredUntil lets us auto-expire boosts so a sold listing doesn't stay
  // pinned forever.
  featured      Boolean   @default(false)
  featuredUntil DateTime? @map("featured_until")

  // Geo coordinates for location-based discovery
  latitude  Float? @map("latitude")
  longitude Float? @map("longitude")

  sellerId String @map("seller_id")
  seller   User   @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)

  // Reviews relation
  reviews Review[]

  // Offers and interests (FB Marketplace-style negotiation)
  offers    ListingOffer[]    @relation("ListingOffers")
  interests ListingInterest[] @relation("ListingInterests")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([latitude, longitude], map: "listings_geo_idx")
  @@index([status, createdAt], map: "listings_status_created_idx")
  @@index([featured, featuredUntil], map: "marketplace_featured_idx")
  @@map("marketplace_listings")
}

model ChatMessage {
  id          String   @id @default(cuid())
  chatGroupId String   @map("chat_group_id")
  senderId    String   @map("sender_id")
  content     String
  timestamp   DateTime @default(now())
  users       User[]

  @@map("chat_messages")
}

// Club membership model with roles
model ClubMember {
  id       String         @id @default(cuid())
  clubId   String         @map("club_id")
  userId   String         @map("user_id")
  role     ClubMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now()) @map("joined_at")

  // ── Moderation state (Discord-style, club-wide) ──────────────────────────
  // `status` is the fast-path flag; the *Until fields back it so timed
  // punishments auto-expire without a cron (callers treat an elapsed
  // timestamp as ACTIVE and lazily reset on next write). bannedUntil far in
  // the future == permanent ban.
  status         ClubMemberStatus @default(ACTIVE)
  mutedUntil     DateTime?        @map("muted_until")
  suspendedUntil DateTime?        @map("suspended_until")
  bannedUntil    DateTime?        @map("banned_until")

  // ── Activity analytics (surfaced in the web club-admin dashboard) ────────
  lastInteractionAt DateTime? @map("last_interaction_at") // any club action
  lastMessageAt     DateTime? @map("last_message_at") // last chat message in a club group
  messageCount      Int       @default(0) @map("message_count")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId, status], map: "club_members_status_idx")
  @@map("club_members")
}

// Append-only audit trail of moderation actions taken by club admins.
// Target/actor are stored as bare userIds (no back-relations) to avoid
// bloating the already-large User model; the club relation is enough for
// the admin moderation-log query.
model ClubModerationAction {
  id           String                   @id @default(cuid())
  clubId       String                   @map("club_id")
  targetUserId String                   @map("target_user_id")
  actorId      String                   @map("actor_id")
  action       ClubModerationActionType
  reason       String?
  expiresAt    DateTime?                @map("expires_at") // for timed mute/suspend/ban
  createdAt    DateTime                 @default(now()) @map("created_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, targetUserId], map: "club_mod_actions_target_idx")
  @@index([clubId, createdAt(sort: Desc)], map: "club_mod_actions_feed_idx")
  @@map("club_moderation_actions")
}

// Club join request for private clubs or moderated joins
model ClubJoinRequest {
  id        String                @id @default(cuid())
  clubId    String                @map("club_id")
  userId    String                @map("user_id")
  message   String? // Optional message from the requester
  status    ClubJoinRequestStatus @default(PENDING)
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@map("club_join_requests")
}

enum ClubJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Ride participant model to track participation
model RideParticipant {
  id       String                @id @default(cuid())
  rideId   String                @map("ride_id")
  userId   String                @map("user_id")
  status   RideParticipantStatus @default(ACCEPTED)
  joinedAt DateTime              @default(now()) @map("joined_at")

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rideId, userId])
  @@map("ride_participants")
}

// Post model for the feed system
model Post {
  id      String   @id @default(cuid())
  type    String // "ride", "content", "listing", "club-activity", "announcement"
  content String?
  images  String[] // Array of image URLs

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Optional relations to other models
  rideId    String? @map("ride_id")
  listingId String? @map("listing_id")
  clubId    String? @map("club_id")

  // Announcement / disappearing post support
  isAnnouncement Boolean   @default(false) @map("is_announcement")
  isPinned       Boolean   @default(false) @map("is_pinned")
  expiresAt      DateTime? @map("expires_at") // null = permanent

  // Interactions
  likes    Like[]
  comments Comment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clubId, createdAt(sort: Desc)], map: "posts_club_feed_idx")
  @@index([expiresAt], map: "posts_expires_idx")
  @@map("posts")
}

// Like model for posts
model Like {
  id     String @id @default(cuid())
  postId String @map("post_id")
  userId String @map("user_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId])
  @@map("likes")
}

// Comment model for posts
model Comment {
  id       String @id @default(cuid())
  postId   String @map("post_id")
  authorId String @map("author_id")
  content  String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("comments")
}

// Follow model for user relationships
model Follow {
  id          String @id @default(cuid())
  followerId  String @map("follower_id")
  followingId String @map("following_id")

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@map("follows")
}

// Review/Rating model for marketplace listings
model Review {
  id         String  @id @default(cuid())
  listingId  String  @map("listing_id")
  reviewerId String  @map("reviewer_id")
  rating     Float // 1.0 to 5.0
  comment    String?

  listing  MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewer User               @relation("ReviewReceiver", fields: [reviewerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([listingId, reviewerId])
  @@map("reviews")
}

model Report {
  id               String  @id @default(cuid())
  type             String
  title            String
  description      String?
  reportedItemId   String? @map("reported_item_id")
  reportedItemName String? @map("reported_item_name")
  reportedItemType String? @map("reported_item_type")
  status           String  @default("pending")
  priority         String  @default("medium")
  resolution       String?

  reporterId String? @map("reporter_id")
  reporter   User?   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("reports")
}

// ============================================
// USER PROFILE ENHANCEMENT MODELS
// ============================================

// Bike model for user's motorcycles
enum BikeType {
  SPORT
  CRUISER
  TOURING
  ADVENTURE
  NAKED
  CAFE_RACER
  DUAL_SPORT
  SCOOTER
  COMMUTER
  SUPERBIKE
  OTHER
}

model Bike {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  make         String // e.g., "Yamaha", "Honda", "Royal Enfield"
  model        String // e.g., "R15 V4", "Meteor 350"
  year         Int // e.g., 2023
  type         BikeType  @default(OTHER)
  engineCc     Int?      @map("engine_cc") // Engine displacement in cc
  color        String?
  licensePlate String?   @map("license_plate")
  vin          String? // Vehicle Identification Number
  odo          Int       @default(0) // Odometer reading in km
  ownerSince   DateTime? @map("owner_since")
  isPrimary    Boolean   @default(false) @map("is_primary")
  image        String? // Bike image URL

  // Modifications stored as JSON
  modifications Json? // { exhaust, tyres, lights, phoneMount, etc. }

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bikes")
}

// Badge definitions (master list of all badges)
model Badge {
  id          String  @id @default(cuid())
  title       String  @unique // e.g., "First Ride", "1000 KM Club"
  description String?
  icon        String? // Emoji or icon URL
  auraPoints  Int     @default(0) @map("aura_points") // XP/Aura points awarded
  category    String? // e.g., "distance", "social", "achievement"
  requirement String? // Description of how to earn this badge

  // Users who have earned this badge
  users UserBadge[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("badges")
}

// Junction table for users and their earned badges
model UserBadge {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// Emergency contacts for user safety
model EmergencyContact {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  name         String
  phone        String
  relationship String? // e.g., "Spouse", "Parent", "Friend", "Sibling"
  isPrimary    Boolean @default(false) @map("is_primary")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("emergency_contacts")
}

// User preferences for app settings
model UserPreferences {
  id                String  @id @default(cuid())
  userId            String  @unique @map("user_id")
  rideReminders     Boolean @default(true) @map("ride_reminders")
  serviceReminderKm Int     @default(3000) @map("service_reminder_km")
  darkMode          Boolean @default(false) @map("dark_mode")
  units             String  @default("metric") // "metric" or "imperial"
  openToInvite      Boolean @default(true) @map("open_to_invite")

  // Notification preferences
  pushNotifications  Boolean @default(true) @map("push_notifications")
  emailNotifications Boolean @default(true) @map("email_notifications")
  smsNotifications   Boolean @default(false) @map("sms_notifications")

  // Privacy settings
  profileVisibility String  @default("public") @map("profile_visibility") // "public", "friends", "private"
  showLocation      Boolean @default(true) @map("show_location")
  showBikes         Boolean @default(true) @map("show_bikes")
  lowDataMode       Boolean @default(false) @map("low_data_mode")
  showStats         Boolean @default(true) @map("show_stats")
  // Beta sensor/ghost-mode toggles — persisted so the live ride and ghost
  // location settings survive logout. Default off because the flow assumes
  // explicit opt-in (battery + privacy implications).
  sensorMode        Boolean @default(false) @map("sensor_mode")
  ghostMode         Boolean @default(false) @map("ghost_mode")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

// User ride statistics (aggregated data)
model UserRideStats {
  id                String @id @default(cuid())
  userId            String @unique @map("user_id")
  totalDistanceKm   Int    @default(0) @map("total_distance_km")
  longestRideKm     Int    @default(0) @map("longest_ride_km")
  totalRides        Int    @default(0) @map("total_rides")
  nightRides        Int    @default(0) @map("night_rides")
  weekendRides      Int    @default(0) @map("weekend_rides")
  soloRides         Int    @default(0) @map("solo_rides")
  groupRides        Int    @default(0) @map("group_rides")
  avgRideDistanceKm Float  @default(0) @map("avg_ride_distance_km")
  totalRideTimeMin  Int    @default(0) @map("total_ride_time_min") // Total time in minutes

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_ride_stats")
}

// Friendship model for mutual connections (different from followers)
enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String           @map("sender_id")
  receiverId String           @map("receiver_id")
  status     FriendshipStatus @default(PENDING)

  sender   User @relation("FriendInitiator", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("FriendReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([senderId, receiverId])
  @@map("friendships")
}

// Friend groups (crew / squad for organizing rides with specific friends)
model FriendGroup {
  id                   String  @id @default(cuid())
  name                 String
  description          String?
  image                String? // Group avatar
  creatorId            String  @map("creator_id")
  clubId               String? @map("club_id")
  joinApprovalRequired Boolean @default(false) @map("join_approval_required")

  // ── WhatsApp-Community fields ────────────────────────────────────────────
  // Every club auto-gets exactly one isAnnouncement group (admin-post-only by
  // default via postPolicy). `conversationId` is the Mongo Conversation _id
  // that backs this group's chat — null until lazily linked on first open.
  isAnnouncement Boolean @default(false) @map("is_announcement")
  postPolicy     String  @default("ALL") @map("post_policy") // ALL | ADMINS_ONLY
  conversationId String? @map("conversation_id")

  creator      User                     @relation("FriendGroupOwner", fields: [creatorId], references: [id], onDelete: Cascade)
  club         Club?                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members      FriendGroupMember[]
  joinRequests FriendGroupJoinRequest[]
  rides        Ride[]                   @relation("FriendGroupRides")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clubId])
  @@map("friend_groups")
}

enum FriendGroupJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model FriendGroupJoinRequest {
  id        String                       @id @default(cuid())
  groupId   String                       @map("group_id")
  userId    String                       @map("user_id")
  message   String?
  status    FriendGroupJoinRequestStatus @default(PENDING)
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")

  group FriendGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, status])
  @@map("friend_group_join_requests")
}

model FriendGroupMember {
  id      String @id @default(cuid())
  groupId String @map("group_id")
  userId  String @map("user_id")

  group FriendGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([groupId, userId])
  @@map("friend_group_members")
}

// Live location sharing (Snapchat-style friend map)
model UserLiveLocation {
  id        String  @id @default(cuid())
  userId    String  @unique @map("user_id")
  latitude  Float
  longitude Float
  altitude  Float?
  heading   Float? // Direction in degrees (0-360)
  speed     Float? // Speed in km/h
  accuracy  Float? // GPS accuracy in meters
  battery   Int? // Battery percentage (0-100)
  isMoving  Boolean @default(false) @map("is_moving")
  isOnRide  Boolean @default(false) @map("is_on_ride")
  rideId    String? @map("ride_id") // If currently on a ride

  // Sharing settings
  sharingEnabled Boolean @default(true) @map("sharing_enabled")
  shareWithAll   Boolean @default(false) @map("share_with_all") // Share with all friends
  ghostMode      Boolean @default(true) @map("ghost_mode") // Hide from everyone

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime? @map("expires_at") // Auto-expire location after time
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([latitude, longitude])
  @@index([updatedAt])
  @@map("user_live_locations")
}

// Who can see a user's location (fine-grained control)
model LocationSharePermission {
  id            String  @id @default(cuid())
  userId        String  @map("user_id") // The user sharing their location
  friendId      String  @map("friend_id") // The friend who can see it
  canSee        Boolean @default(true) @map("can_see")
  canSeeSpeed   Boolean @default(true) @map("can_see_speed")
  canSeeBattery Boolean @default(false) @map("can_see_battery")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, friendId])
  @@map("location_share_permissions")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────────────────
// RIDE RATINGS - Post-ride user ratings and reputation
// ─────────────────────────────────────────────────────────────────────────────

model RideRating {
  id          String   @id @default(cuid())
  rideId      String   @map("ride_id")
  ratedById   String   @map("rated_by_id") // Who is giving the rating
  ratedUserId String   @map("rated_user_id") // Who is being rated
  rating      Int      @db.SmallInt // 1-5 stars
  comment     String?
  tags        String[] // Quick tags: "Safe", "Friendly", "Skilled", "Reliable", etc.

  ride      Ride @relation("RideRatings", fields: [rideId], references: [id], onDelete: Cascade)
  ratedBy   User @relation("RideRatingGiver", fields: [ratedById], references: [id], onDelete: Cascade)
  ratedUser User @relation("RideRatingReceiver", fields: [ratedUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([rideId, ratedById, ratedUserId], map: "unique_ride_rating")
  @@index([ratedUserId], map: "idx_rated_user")
  @@map("ride_ratings")
}

// ─────────────────────────────────────────────────────────────────────────────
// MARKETPLACE OFFERS - Facebook Marketplace-style negotiation flow
// From interest shown → offer made → negotiation → deal done
// ─────────────────────────────────────────────────────────────────────────────

enum ListingOfferStatus {
  INTERESTED // Initial interest shown
  OFFER_MADE // Buyer made an offer
  NEGOTIATING // Counter-offers in progress
  ACCEPTED // Seller accepted offer
  DEAL_DONE // Completion/payment done
  REJECTED // Offer rejected
  WITHDRAWN // Buyer withdrew offer
  EXPIRED // Offer expired (time limit)
}

model ListingOffer {
  id        String             @id @default(cuid())
  listingId String             @map("listing_id")
  buyerId   String             @map("buyer_id")
  status    ListingOfferStatus @default(INTERESTED)

  // Offer details
  originalPrice Float?  @map("original_price") // Listing price
  offeredPrice  Float?  @map("offered_price") // What buyer is offering
  message       String? // Buyer's message/negotiation note

  // Negotiation history (JSON array of offer/counter-offer chain)
  negotiationHistory String? @map("negotiation_history") // JSON formatted

  // Timeline
  lastMessageAt DateTime? @map("last_message_at")
  expiresAt     DateTime? @map("expires_at") // Offer expires after X days

  listing MarketplaceListing @relation("ListingOffers", fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User               @relation("ListingOffersBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([listingId, buyerId], map: "unique_buyer_per_listing")
  @@index([status], map: "idx_offer_status")
  @@index([buyerId], map: "idx_buyer_id")
  @@map("listing_offers")
}

model ListingInterest {
  id        String @id @default(cuid())
  listingId String @map("listing_id")
  userId    String @map("user_id") // User who showed interest

  listing MarketplaceListing @relation("ListingInterests", fields: [listingId], references: [id], onDelete: Cascade)
  user    User               @relation("ListingInterests", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([listingId, userId], map: "unique_listing_interest")
  @@map("listing_interests")
}

