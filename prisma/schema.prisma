// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS - Track notifications sent to users
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationType {
  RIDE_INVITE // Invited to a ride
  RIDE_JOINED // Someone joined your ride
  RIDE_COMPLETED // Ride completed reminder
  CLUB_INVITE // Invited to club
  CLUB_REQUEST // New member request
  LISTING_OFFER // Received offer on listing
  LISTING_INTERESTED // Someone interested in listing
  MESSAGE // New chat message
  FOLLOW // New follower
  COMMENT // Comment on your post
  LIKE // Like on your post
  FRIEND_REQUEST // Friend request received
}

model Notification {
  id      String           @id @default(cuid())
  userId  String           @map("user_id")
  type    NotificationType
  title   String
  message String?

  // Link to the related entity
  relatedType String? @map("related_type") // "ride", "club", "listing", "user", "post", etc
  relatedId   String? @map("related_id")

  // Delivery tracking
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  // Delivery channels
  sentViaEmail Boolean @default(false) @map("sent_via_email")
  sentViaPush  Boolean @default(false) @map("sent_via_push")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "idx_notification_user")
  @@index([isRead], map: "idx_notification_read")
  @@index([createdAt], map: "idx_notification_created")
  @@map("notifications")
}
